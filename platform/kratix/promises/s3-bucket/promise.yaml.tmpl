apiVersion: platform.kratix.io/v1alpha1
kind: Promise
metadata:
  name: s3-bucket
  labels:
    kratix.io/promise-version: v0.1.0
spec:
  api:
    apiVersion: apiextensions.k8s.io/v1
    kind: CustomResourceDefinition
    metadata:
      name: s3buckets.platform.demoteam.dev
    spec:
      group: platform.demoteam.dev
      names:
        kind: S3Bucket
        plural: s3buckets
        singular: s3bucket
      scope: Namespaced
      versions:
        - name: v1alpha1
          served: true
          storage: true
          subresources:
            status: {}
          schema:
            openAPIV3Schema:
              type: object
              properties:
                spec:
                  type: object
                  properties:
                    bucketName:
                      type: string
                    region:
                      type: string
                      default: us-east-1
                    iamUserName:
                      type: string
                    consumers:
                      type: array
                      items:
                        type: object
                        required:
                          - name
                          - workloadSelector
                        properties:
                          name:
                            type: string
                          workloadSelector:
                            type: object
                            required:
                              - matchLabels
                            properties:
                              matchLabels:
                                type: object
                                additionalProperties:
                                  type: string
  workflows:
    resource:
      configure:
        - apiVersion: platform.kratix.io/v1alpha1
          kind: Pipeline
          metadata:
            name: configure-s3-bucket
          spec:
            containers:
              - name: configure
                image: __S3_BUCKET_PIPELINE_IMAGE__
                env:
                  - name: AWS_ADMIN_ACCESS_KEY_ID
                    valueFrom:
                      secretKeyRef:
                        name: aws-admin-credentials
                        key: ACCESS_KEY_ID
                  - name: AWS_ADMIN_SECRET_ACCESS_KEY
                    valueFrom:
                      secretKeyRef:
                        name: aws-admin-credentials
                        key: SECRET_ACCESS_KEY
