apiVersion: platform.kratix.io/v1alpha1
kind: Promise
metadata:
  name: api-access
  labels:
    kratix.io/promise-version: v0.1.0
spec:
  api:
    apiVersion: apiextensions.k8s.io/v1
    kind: CustomResourceDefinition
    metadata:
      name: ciliumapiaccesses.platform.demoteam.dev
    spec:
      group: platform.demoteam.dev
      names:
        kind: CiliumAPIAccess
        plural: ciliumapiaccesses
        singular: ciliumapiaccess
      scope: Namespaced
      versions:
        - name: v1alpha1
          served: true
          storage: true
          subresources:
            status: {}
          schema:
            openAPIV3Schema:
              type: object
              required:
                - spec
              properties:
                spec:
                  type: object
                  required:
                    - workloadSelector
                    - destination
                    - rules
                  properties:
                    workloadSelector:
                      type: object
                      required:
                        - matchLabels
                      properties:
                        matchLabels:
                          type: object
                          additionalProperties:
                            type: string
                    destination:
                      type: object
                      required:
                        - port
                      oneOf:
                        - required:
                            - service
                        - required:
                            - fqdn
                      properties:
                        service:
                          type: object
                          required:
                            - name
                            - namespace
                          properties:
                            name:
                              type: string
                            namespace:
                              type: string
                        fqdn:
                          type: string
                        podSelector:
                          type: object
                          properties:
                            matchLabels:
                              type: object
                              additionalProperties:
                                type: string
                        port:
                          type: integer
                          minimum: 1
                          maximum: 65535
                        protocol:
                          type: string
                          default: TCP
                          enum:
                            - TCP
                    rules:
                      type: array
                      minItems: 1
                      items:
                        type: object
                        required:
                          - method
                          - path
                        properties:
                          method:
                            type: string
                          path:
                            type: string
  workflows:
    resource:
      configure:
        - apiVersion: platform.kratix.io/v1alpha1
          kind: Pipeline
          metadata:
            name: configure-api-access
          spec:
            containers:
              - name: configure
                image: __CILIUM_API_ACCESS_PIPELINE_IMAGE__
