apiVersion: platform.kratix.io/v1alpha1
kind: Promise
metadata:
  name: ns-lockdown
  labels:
    kratix.io/promise-version: v0.1.0
spec:
  api:
    apiVersion: apiextensions.k8s.io/v1
    kind: CustomResourceDefinition
    metadata:
      name: ciliumnamespacelockdowns.platform.demoteam.dev
    spec:
      group: platform.demoteam.dev
      names:
        kind: CiliumNamespaceLockdown
        plural: ciliumnamespacelockdowns
        singular: ciliumnamespacelockdown
      scope: Namespaced
      versions:
        - name: v1alpha1
          served: true
          storage: true
          subresources:
            status: {}
          schema:
            openAPIV3Schema:
              type: object
              properties:
                spec:
                  type: object
                  properties:
                    allowDNS:
                      type: boolean
                      default: true
  workflows:
    resource:
      configure:
        - apiVersion: platform.kratix.io/v1alpha1
          kind: Pipeline
          metadata:
            name: configure-ns-lockdown
          spec:
            containers:
              - name: configure
                image: __CILIUM_NAMESPACE_LOCKDOWN_PIPELINE_IMAGE__
