apiVersion: apps/v1
kind: Deployment
metadata:
  name: __TODOS_API_NAME__
  namespace: __DEMO_NAMESPACE__
  labels:
    app.kubernetes.io/name: __TODOS_API_NAME__
    app.kubernetes.io/component: provider-api
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: __TODOS_API_NAME__
  template:
    metadata:
      labels:
        app.kubernetes.io/name: __TODOS_API_NAME__
        app.kubernetes.io/component: provider-api
    spec:
      containers:
        - name: todos-api
          image: __TODOS_API_IMAGE__
          imagePullPolicy: IfNotPresent
          ports:
            - name: http
              containerPort: __TODOS_API_PORT__
          env:
            - name: PORT
              value: "__TODOS_API_PORT__"
          readinessProbe:
            httpGet:
              path: /ready
              port: http
            initialDelaySeconds: 2
            periodSeconds: 5
---
apiVersion: v1
kind: Service
metadata:
  name: __TODOS_API_NAME__
  namespace: __DEMO_NAMESPACE__
  labels:
    app.kubernetes.io/name: __TODOS_API_NAME__
spec:
  selector:
    app.kubernetes.io/name: __TODOS_API_NAME__
  ports:
    - name: http
      port: __TODOS_API_PORT__
      targetPort: http

